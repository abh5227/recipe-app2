# The database is generated by build_db.py AND holds personal data
# (your ratings and cook history). Don't commit it.
recipes.db
recipes.db-journal
recipes.db-wal
recipes.db-shm

# Local backups (made by backup.py)
backups/

# Design-review preview HTML (generated; viewed locally, never committed)
previews/

# Paprika recipe exports — bulk data, not code (the native archive is 200 MB+).
# Read-only import tooling unpacks these to a scratch dir; never commit them.
*.paprikarecipes
*.paprikarecipe

# Paprika HTML-export study data — no longer the import source (we're on native now);
# kept on disk as possible fallback-reader material for the friends-migration tool.
/index.html
/paprika_samples/

# Python bytecode caches
__pycache__/
*.pyc

# Virtual environment, if you make one
.venv/
venv/

# Claude Code local settings (permissions, not project config)
.claude/

# Editor / OS noise
.vscode/
.DS_Store
